{
  "name": "booking-system-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/scripts/seed.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "db:reset": "npx prisma migrate reset --force",
    "db:seed": "node src/scripts/seed.js",
    "db:fresh": "npx prisma migrate reset --force && node src/scripts/seed.js && node src/scripts/resetOS.js",
    "db:studio": "npx prisma studio",
    "users:unlock": "node src/scripts/unlockUsers.js",
    "users:patch-active": "node src/scripts/patchUserIsActive.js",
    "es:reset": "node src/scripts/resetOS.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.4.5",
    "@opensearch-project/opensearch": "^3.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "amqplib": "^2.0.1",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "sepay-pg-node": "^1.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "vnpay": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^7.7.0"
  }
